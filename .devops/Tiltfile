# krispyai — local dev via Tilt + Vercel Portless.
#
# Every SERVED role (has a URL) is wrapped with portless so it gets a stable,
# named URL instead of a pinned port: <service>.krispy.localhost:1355.
# Portless injects a random PORT and proxies the named URL → that port, so
# NOTHING here pins a service port. Every served role reads process.env.PORT.
#
# The map: apps/ = public UI · services/ = has a URL · libs/ = shared, never
# served (so no Tilt resource — except the design system's Storybook, which IS
# served for humans).
#
# Only Krispy's REAL resources boot here. The forked builders-stack shipped a few
# example services (services/api Hono demo, services/ai-worker in-memory queue
# sample) + a builders-stack deploy flow — those are NOT part of Krispy and are
# intentionally absent (see the "Removed" note in Services below).
#
# See docs/portless.md for the convention and the full URL table.

os.putenv('PATH', os.environ['HOME'] + '/.bun/bin:' + os.environ.get('PATH', ''))

# Direct bun binary — bypasses the proto shim (~/.proto/shims/bun) that rewrites
# `bun run X` to `moon run :X`, which breaks bare targets inside local_resource.
BUN = os.environ['HOME'] + '/.bun/bin/bun'

update_settings(max_parallel_updates=4)
docker_prune_settings(disable=True)

# Repo root (this Tiltfile lives in .devops/, loaded via load_dynamic from root).
REPO_ROOT = str(local('cd .. && pwd', quiet=True)).strip()

print('=' * 60)
print('KRISPY TILT - LOCAL (portless)')
print('=' * 60)

# All served roles share this scheme. <service>.krispy.localhost:1355
PORTLESS_PROXY = 'http://{}.krispy.localhost:1355'

# Sourced into each service so DATABASE_URL / secrets from .env.local reach the
# process. Cross-service URLs are injected AFTER this (via portless_cmd env=), so
# they win over any stale values in .env.local.
ENV_LOCAL = 'set -a && [ -f ' + REPO_ROOT + '/.env.local ] && . ' + REPO_ROOT + '/.env.local; set +a; '

# Portless wrapper: retry route registration with backoff to survive cross-project
# lock contention (portless has a ~1s internal lock budget; another project
# registering at the same moment can exceed it). Pass health_url to add a watchdog
# that kills the process group if the URL stops responding, so Tilt restarts it
# (fixes: portless stays alive while bun --watch silently loops on a crashed server).
def portless_cmd(args, env='', health_url=''):
    cmd = (env + ' ' if env else '') + 'portless --force ' + args
    retry = 'for i in 1 2 3 4 5; do ' + cmd + ' && break || echo "portless lock failed (attempt $i/5), retrying in ${i}s..." && sleep $i; done'
    if not health_url:
        return retry
    watchdog = '(sleep 20; FAILS=0; while true; do sleep 10; ' + 'if curl -sf -o /dev/null ' + health_url + ' 2>/dev/null; then FAILS=0; ' + 'else FAILS=$((FAILS+1)); echo "[watchdog] health check failed ($FAILS/3) for ' + health_url + '"; ' + 'if [ $FAILS -ge 3 ]; then echo "[watchdog] killing process group after 3 failed checks"; kill 0; exit 1; fi; ' + 'fi; done) &'
    # Wrap in { } so the backgrounded watchdog (&) doesn't break the parent shell.
    return '{ ' + watchdog + ' ' + retry + '; }'

# =============================================================================
# Services (served — have a URL, wrapped with portless)
#
# Removed vs. the builders-stack fork (not part of Krispy, so they don't boot):
#   • api        — the Hono + Better Auth demo. NOTE: web's auth-client still
#                  points at its /api/auth/*; auth backend needs rehoming before
#                  web login works locally again.
#   • ai-worker  — a "summarize" in-memory-queue sample worker. Krispy's AI runs
#                  inside `edge` via the Workers AI binding, not a side worker.
#                  (If Krispy ever needs a no-URL background worker, mirror the
#                  plain local_resource pattern — no portless, since it has no URL.)
# =============================================================================

# edge — THE product Worker (live-chat + human-handoff): /api/chat, /api/contact,
# the Telegram webhook, the SessionDO WebSocket fan-out, and the /api/billing
# entitlement push endpoint. Runs on Cloudflare's local runtime via `wrangler dev`.
#
# Portless quirk: wrangler ignores PORT env (unlike our bun/next services) — it
# only takes --port. Portless injects PORT into the *child's* env, so we hand it
# `sh -c '… --port $PORT'` (single-quoted): the OUTER shell must NOT expand $PORT,
# the inner sh (which portless spawns with PORT set) does. cd into services/edge so
# wrangler finds wrangler.toml; KV/DO run under local Miniflare (placeholder id ok).
local_resource(
    'edge',
    serve_cmd='cd ' + REPO_ROOT + ' && ' + ENV_LOCAL + portless_cmd(
        "edge.stack sh -c 'cd " + REPO_ROOT + "/services/edge && " + BUN + " x wrangler dev --port $PORT'",
        health_url=PORTLESS_PROXY.format('edge') + '/health'),
    links=[PORTLESS_PROXY.format('edge') + '/health'],
    labels=['services'],
)

# payment — the REAL Krispy Cloud billing app (@krispy/billing over Hono): mounts
# /api/billing/* (subscriptions, trials, entitlement) plus a Creem checkout/webhook.
# Runs standalone on process.env.PORT. Boots on the Mock provider until CREEM_API_KEY
# is set; point Creem webhooks at this URL via the `tunnel` button.
local_resource(
    'payment',
    serve_cmd='cd ' + REPO_ROOT + ' && ' + ENV_LOCAL + portless_cmd(
        'payment.stack ' + BUN + ' --filter @krispy/payment dev',
        health_url=PORTLESS_PROXY.format('payment') + '/health'),
    links=[PORTLESS_PROXY.format('payment') + '/health'],
    labels=['services'],
)

# =============================================================================
# Apps (served to humans, wrapped with portless)
# =============================================================================

# web — Next.js — the Krispy Cloud dashboard. portless sets PORT; `next dev`
# (no --port) binds it. (The api/auth cross-URL env was dropped with the `api`
# demo service — see the Removed note above; the dashboard UI still boots, only
# Better Auth calls have no backend until auth is rehomed.)
local_resource(
    'web',
    serve_cmd='cd ' + REPO_ROOT + ' && ' + ENV_LOCAL + portless_cmd(
        'web.stack ' + BUN + ' --filter @krispy/web dev',
        health_url=PORTLESS_PROXY.format('web')),
    links=[PORTLESS_PROXY.format('web')],
    labels=['apps'],
)

# landing — public marketing Next.js app. Same portless pattern as web; NEXT_PUBLIC_APP_URL
# points "Log in / Get started" at the web app. Public — no auth, no session redirects.
local_resource(
    'landing',
    serve_cmd='cd ' + REPO_ROOT + ' && ' + ENV_LOCAL + portless_cmd(
        'landing.stack ' + BUN + ' --filter @krispy/landing dev',
        env='NEXT_PUBLIC_APP_URL=' + PORTLESS_PROXY.format('web') +
            ' NEXT_PUBLIC_BLOG_URL=' + PORTLESS_PROXY.format('blog'),
        health_url=PORTLESS_PROXY.format('landing')),
    links=[PORTLESS_PROXY.format('landing')],
    labels=['apps'],
)

# blog — public static (SSG) Next.js blog + SEO/GEO showcase. Same portless pattern as
# landing. NEXT_PUBLIC_LANDING_URL points its header back at the marketing site. Public —
# no auth, no session redirects. Deployed to its own subdomain (blog.<domain>) in prod.
local_resource(
    'blog',
    serve_cmd='cd ' + REPO_ROOT + ' && ' + ENV_LOCAL + portless_cmd(
        'blog.stack ' + BUN + ' --filter @krispy/blog dev',
        env='NEXT_PUBLIC_LANDING_URL=' + PORTLESS_PROXY.format('landing'),
        health_url=PORTLESS_PROXY.format('blog')),
    links=[PORTLESS_PROXY.format('blog')],
    labels=['apps'],
)

# =============================================================================
# Design system (served — Storybook)
# =============================================================================
# @krispy/ui's storybook script binds `-p ${PORT:-...}`, so portless's injected
# PORT is what it binds and proxies to. It falls back to a default standalone.
local_resource(
    'storybook',
    serve_cmd='cd ' + REPO_ROOT + ' && ' + portless_cmd('storybook.stack ' + BUN + ' --filter @krispy/ui storybook'),
    links=[PORTLESS_PROXY.format('storybook')],
    labels=['design-system'],
)

# =============================================================================
# One-off flows (click-to-run buttons in the Tilt UI; auto_init=False = don't
# run on boot). Builders-stack deploy flow (deploy:staging) dropped — it assumed
# the example stack, not Krispy's deploy targets.
# =============================================================================

# db:push — drizzle-kit push of the @krispy/db schema (includes the billing tables
# the payment service reads/writes). Click after a schema change.
local_resource(
    'db:push',
    cmd='cd ' + REPO_ROOT + ' && ' + ENV_LOCAL + BUN + ' --filter @krispy/db push',
    auto_init=False,
    labels=['flows'],
)

# tunnel — public HTTPS tunnel for local dev, needed so Telegram can reach the
# edge Worker's /api/telegram/webhook (and Creem can reach payment's webhook).
local_resource(
    'tunnel',
    cmd='cd ' + REPO_ROOT + ' && ./scripts/tunnel.sh',
    auto_init=False,
    trigger_mode=TRIGGER_MODE_MANUAL,
    labels=['flows'],
)

print("""
================================================================================
                        KRISPY — LOCAL DEVELOPMENT (Portless)
================================================================================
  Web:       http://web.krispy.localhost:1355        (Krispy Cloud dashboard)
  Landing:   http://landing.krispy.localhost:1355
  Blog:      http://blog.krispy.localhost:1355
  Edge:      http://edge.krispy.localhost:1355       (/health · product Worker)
  Payment:   http://payment.krispy.localhost:1355    (/health · /api/billing/*)
  Storybook: http://storybook.krispy.localhost:1355

  Flows (click in the Tilt UI): db:push · tunnel
  Portless proxy: install with `npm install -g portless` (starts automatically).
================================================================================
""")
