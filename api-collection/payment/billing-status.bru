meta {
  name: Billing - status
  type: http
  seq: 3
}

get {
  url: {{paymentUrl}}/api/billing/status?tenantId=tenant_demo
  body: none
  auth: none
}

params:query {
  tenantId: tenant_demo
}

tests {
  test("responds 200", function() {
    expect(res.status).to.equal(200);
  });
  test("reports plan + entitlement", function() {
    expect(res.getBody().plan).to.be.a("string");
    expect(res.getBody().entitled).to.be.a("boolean");
  });
}
